# Cango FamilyGraph + source definitions (V1 single source of truth).
# Copy to /data/cango/family.yaml and fill in real feeds + credentials.
#
# Each source's `ownerId` is the person whose availability the source's events
# count against. For an organization feed (a club, a school) that a family
# member follows, set ownedBy: organization but point ownerId at the *person*
# who attends — that's the personId stamped on every event from the feed, and
# the key attendance edges resolve against.

settings:
  refreshIntervalMinutes: 60
  maxStaleHours: 6
  # IANA timezone for formatting event times and reading offset-less inputs.
  timezone: Europe/Stockholm

people:
  - id: p-me
    name: Me
    sourceIds: [src-work, src-personal]
    # Optional: addresses used to match this person against an event's ATTENDEE
    # props (e.g. when create_event writes attendees, or an invite lists them).
    # A person with no email is simply never ATTENDEE-matched — they can still
    # be an occupant via a source default or a fan-out rule. The kids' addresses
    # don't have to be real mailboxes; they just have to match what cango writes.
    emails: [me@example.com]
  - id: p-wife
    name: Wife
    sourceIds: [src-wife-work]
    emails: [wife@example.com]
  - id: p-kid
    name: Kid
    sourceIds: [src-football]

# Named sets of people, so occupancy can say "family" instead of listing every
# id. Members may be people or other groups (expanded, cycle-guarded). Used by a
# source's `defaultOccupants` and by fan-out rules (effect: fanout).
groups:
  - id: family
    name: Everyone
    memberIds: [p-me, p-wife, p-kid]

organizations:
  - id: org-football
    name: Local Football Club
    sourceIds: [src-football]

sources:
  # Work calendar over CalDAV. Many meetings are optional — record a `soft` rule
  # for them at runtime via the agent (record_rule); rules are no longer in YAML.
  - id: src-work
    kind: caldav
    ownedBy: person
    ownerId: p-me
    defaultRole: hard
    serverUrl: https://caldav.example.com/
    username: me@example.com
    password: ${CANGO_WORK_PASSWORD}   # daemon expands from /etc/cango.env
    calendarName: Work
    selfEmail: me@example.com
    # Optional: pin the exact calendar-collection URL (as DAVx5 or the server's
    # web UI report it). When set, the adapter talks straight to it and skips
    # CalDAV auto-discovery — use this if your server's /.well-known/caldav is
    # broken, or to avoid relying on calendarName matching.
    # calendarUrl: https://caldav.example.com/remote.php/dav/calendars/me/work/
    # Opt-in: allow the daemon to CREATE events on this calendar via the
    # create_event tool. Default false. Only valid for caldav sources —
    # setting it on an ics source is a config error.
    writable: true

  # Personal ICS feed (read-only share URL).
  - id: src-personal
    kind: ics
    ownedBy: person
    ownerId: p-me
    defaultRole: hard
    url: https://calendar.example.com/me/personal.ics

  - id: src-wife-work
    kind: ics
    ownedBy: person
    ownerId: p-wife
    defaultRole: hard
    url: https://calendar.example.com/wife/work.ics

  # Club feed the kid follows. NEVER_ATTENDS edges (below) suppress the
  # sessions the kid doesn't actually go to.
  - id: src-football
    kind: ics
    ownedBy: organization
    ownerId: p-kid
    defaultRole: info
    url: https://football.example.com/team-a.ics

  # A shared *family* calendar: every event on it occupies the whole household,
  # not just the owner. `defaultOccupants` names the people (or a group) an
  # event here normally occupies; omit it and the baseline is just [ownerId]
  # (the default for every source above). For one-off "include my wife on this
  # event" cases use create_event(occupants=[...]); for recurring household
  # patterns on someone else's calendar use a fan-out rule (effect: fanout).
  - id: src-family
    kind: caldav
    ownedBy: person
    ownerId: p-me
    defaultRole: soft
    defaultOccupants: [family]
    serverUrl: https://caldav.example.com/
    username: me@example.com
    password: ${CANGO_WORK_PASSWORD}
    calendarName: Family
    writable: true

# DEPRECATED — attendance edges are no longer a live config layer. On the
# daemon's first run these are seeded ONCE into the durable rule store
# (state.db) and ignored thereafter; manage rules at runtime via the agent
# (record_rule / amend_rule / forget_rule). Kept here only so an existing
# family.yaml still validates and can be imported on first boot. New setups can
# omit this block and add the equivalent rules through the agent instead.
attendance:
  - personId: p-kid
    seriesId: football-u11-training
    role: ATTENDS
    reason: Kid is on the U11 squad
  - personId: p-kid
    seriesId: football-u9-training
    role: NEVER_ATTENDS
    reason: Wrong age group, ignore
