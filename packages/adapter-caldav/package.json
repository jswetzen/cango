{
  "name": "@cango/adapter-caldav",
  "version": "0.0.0",
  "description": "CalDAV adapter for Cango. Auths, REPORT-queries a window, normalizes to CalEvent.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cango/adapter-ics": "workspace:*",
    "@cango/core": "workspace:*",
    "tsdav": "2.2.2"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
