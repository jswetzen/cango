# Never copy host installs into the image — they're pnpm symlink farms whose
# .pnpm-store targets don't exist in the build, leaving dangling deps. The
# image installs its own deps with bun.
node_modules
**/node_modules

# Build outputs are regenerated inside the image.
dist
**/dist
*.tsbuildinfo

# Local tooling / VCS cruft, not needed in the image.
.git
.pnpm-store
**/.vite
.claude
